NODE_ENV=production
PORT=3000
WEB_PORT=5173

DATABASE_URL=postgres://username:password@db-host:5432/ai_voice_assistant

SESSION_COOKIE_NAME=ai_voice_assistant_session
SESSION_SECRET=replace-with-a-long-random-secret

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="AI Voice Assistant <no-reply@your-domain.com>"

MODEL_BASE_URL=https://your-provider.example.com/v1
MODEL_API_KEY=replace-with-real-model-key
MODEL_NAME=deepseek-chat
